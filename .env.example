# LLM Provider: "azure" (default), "ollama", or "openai"
LLM_PROVIDER="azure"

# Azure OpenAI (when LLM_PROVIDER=azure)
AZURE_API_VERSION="2024-12-01-preview"
AZURE_ENDPOINT="https://your-endpoint.openai.azure.com/"
AZURE_API_KEY="your-key"
AZURE_MODEL_NAME_MINI="gpt-5-mini"
AZURE_DEPLOYMENT_MINI="your-mini-deployment"
AZURE_MODEL_NAME_FULL="gpt-5.2"
AZURE_DEPLOYMENT_FULL="your-full-deployment"

# Ollama (when LLM_PROVIDER=ollama) — free, runs locally
# OLLAMA_BASE_URL="http://localhost:11434/v1"
# OLLAMA_MODEL_MINI="llama3.1"
# OLLAMA_MODEL_FULL="llama3.1"

# OpenAI (when LLM_PROVIDER=openai)
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL_MINI="gpt-4o-mini"
# OPENAI_MODEL_FULL="gpt-4o"

# Auth
JWT_SECRET="change-me-in-production"
ALLOWED_EMAILS="user1@example.com,user2@example.com"
ADMIN_EMAILS="user1@example.com"

# Dataset source API keys (optional)
DATAGOV_API_KEY=""
KAGGLE_API_TOKEN=""
FRED_API_KEY=""
BLS_API_KEY=""
EIA_API_KEY=""

# Sandbox limits
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=512

# Azure Storage (for persistent user accounts; leave empty for in-memory dev mode)
AZURE_STORAGE_CONNECTION_STRING=""

# CORS (comma-separated origins; add your Azure domain for production)
# e.g. CORS_ORIGINS="http://localhost:5173,https://your-app.azurecontainerapps.io"
CORS_ORIGINS="http://localhost:5173"
